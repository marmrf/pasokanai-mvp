# ═══════════════════════════════════════════════════════════════
#  PasokanAI MVP — Environment Variables
#  Copy file ini menjadi .env dan isi nilainya
#  Lihat AZURE-IMPLEMENTATION.md untuk panduan setup setiap service
# ═══════════════════════════════════════════════════════════════

# ─── FRONTEND (Vite — prefix VITE_ wajib ada) ─────────────────

# Supabase project URL
# Cloud:  https://<project-ref>.supabase.co
# Local:  http://127.0.0.1:54321 (dari output `supabase start`)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/public key (aman di frontend karena RLS aktif)
VITE_SUPABASE_ANON_KEY=<anon-key>

# Azure Speech Services — Phase 10 (opsional, belum aktif)
VITE_AZURE_SPEECH_KEY=
VITE_AZURE_SPEECH_REGION=southeastasia

# ─── AZURE FUNCTION (api/local.settings.json) ─────────────────

# Supabase (gunakan Service Role key — RAHASIA, jangan commit)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# Azure OpenAI — GPT-4o-mini untuk negotiation anchor
# Tanpa ini, Gap Alert masih berjalan dengan template response
OPENAI_API_KEY=<azure-openai-api-key>
OPENAI_MODEL=gpt-4o-mini
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/

# Azure ML — Prophet forecasting (Phase 4, belum aktif)
AZURE_ML_ENDPOINT=
AZURE_ML_KEY=

# Azure Speech (backend, Phase 10)
AZURE_SPEECH_KEY=

# Azure Application Insights — monitoring (opsional)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;...

# ─── CATATAN ──────────────────────────────────────────────────
# 1. Frontend: copy ke frontend/.env
#    $ cp .env.example frontend/.env
#
# 2. Azure Functions: copy ke api/local.settings.json
#    Format: {"IsEncrypted": false, "Values": {...env vars...}}
#
# 3. VITE_ variables di-embed ke bundle JS saat build —
#    pastikan TIDAK ada secret di VITE_ vars
#
# 4. Untuk local Supabase:
#    $ supabase start
#    → API URL dan anon key ditampilkan di terminal
#
# 5. Service status: buka http://localhost:5173 dev mode
#    → banner kuning di atas halaman
