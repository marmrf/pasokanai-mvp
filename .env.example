# ═══════════════════════════════════════════════════════════════
#  PasokanAI MVP — Environment Variables
#  Copy file ini menjadi .env dan isi nilainya
# ═══════════════════════════════════════════════════════════════

# ─── FRONTEND (Vite — prefix VITE_ wajib ada) ─────────────────
# Supabase project URL (dari dashboard Supabase → Settings → API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/public key (aman di-expose di frontend karena RLS aktif)
VITE_SUPABASE_ANON_KEY=<anon-key>

# ─── AZURE FUNCTION (api/) ────────────────────────────────────
# Supabase Service Role Key (rahasia! jangan commit)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# Azure OpenAI (untuk negotiation anchor via GPT-4o-mini)
OPENAI_API_KEY=<azure-openai-api-key>
OPENAI_MODEL=gpt-4o-mini

# Azure Application Insights (opsional, untuk monitoring)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;...

# ─── AZURE STATIC WEB APPS ────────────────────────────────────
# Token ini dikonfigurasi di GitHub Actions secrets
# Nama secret: AZURE_STATIC_WEB_APPS_API_TOKEN_POLITE_HILL_0063F5500
# Tidak perlu di .env lokal

# ─── CATATAN UNTUK DEPLOYMENT ─────────────────────────────────
# 1. Frontend .env dibaca oleh Vite saat build (npm run build)
# 2. Azure Function membaca env dari local.settings.json (lokal)
#    atau Application Settings di Azure Portal (production)
# 3. VITE_ variables di-embed ke dalam bundle JS saat build —
#    pastikan tidak ada secret di VITE_ vars
